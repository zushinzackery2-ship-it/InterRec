<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Label="DependencyRoots">
    <DependencyRoot Condition="'$(DependencyRoot)'==''">$(MSBuildThisFileDirectory)..\</DependencyRoot>
    <UrhRoot Condition="'$(UrhRoot)'==''">$(DependencyRoot)Universal-Render-Hook\URH\</UrhRoot>
    <UrhIncludeRoot Condition="'$(UrhIncludeRoot)'==''">$(UrhRoot)include\</UrhIncludeRoot>
    <UrhSourceRoot Condition="'$(UrhSourceRoot)'==''">$(UrhRoot)src\</UrhSourceRoot>
    <VkhRoot Condition="'$(VkhRoot)'==''">$(DependencyRoot)VulkanHook\VulkanHook\</VkhRoot>
    <VkhIncludeRoot Condition="'$(VkhIncludeRoot)'==''">$(VkhRoot)include\</VkhIncludeRoot>
    <VkhSourceRoot Condition="'$(VkhSourceRoot)'==''">$(VkhRoot)src\</VkhSourceRoot>
  </PropertyGroup>
</Project>
