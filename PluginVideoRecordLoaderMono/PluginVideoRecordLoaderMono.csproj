<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Release</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">x64</Platform>
    <ProjectGuid>{AB6851D0-9A6D-4EF9-8803-7C3F8B9FB103}</ProjectGuid>
    <OutputType>Library</OutputType>
    <RootNamespace>PluginVideoRecordLoaderMono</RootNamespace>
    <AssemblyName>PluginVideoRecordLoaderMono</AssemblyName>
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <OutputPath>..\bin\$(Platform)\$(Configuration)\</OutputPath>
    <IntermediateOutputPath>..\obj\$(MSBuildProjectName)\$(Platform)\$(Configuration)\</IntermediateOutputPath>
    <Optimize>true</Optimize>
    <DebugType>none</DebugType>
    <PlatformTarget>x64</PlatformTarget>
    <Prefer32Bit>false</Prefer32Bit>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <Import Project="..\Local.Build.props" Condition="Exists('..\Local.Build.props')" />
  <PropertyGroup>
    <PluginVideoRecordMonoBepInExCoreDir Condition="'$(PluginVideoRecordMonoBepInExCoreDir)' == ''">$(PLUGIN_VIDEO_RECORD_MONO_BEPINEX_CORE_DIR)</PluginVideoRecordMonoBepInExCoreDir>
    <PluginVideoRecordMonoManagedDir Condition="'$(PluginVideoRecordMonoManagedDir)' == ''">$(PLUGIN_VIDEO_RECORD_MONO_MANAGED_DIR)</PluginVideoRecordMonoManagedDir>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="mscorlib" />
    <Reference Include="BepInEx">
      <HintPath>$(PluginVideoRecordMonoBepInExCoreDir)\BepInEx.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>$(PluginVideoRecordMonoManagedDir)\UnityEngine.CoreModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine">
      <HintPath>$(PluginVideoRecordMonoManagedDir)\UnityEngine.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>
  <ItemGroup>
    <Compile Include="PluginVideoRecordLoaderMonoPlugin.cs" />
    <Compile Include="..\PluginVideoRecordLoaderShared\PluginVideoRecordNativeLoader.cs">
      <Link>PluginVideoRecordNativeLoader.cs</Link>
    </Compile>
    <Compile Include="Properties\AssemblyInfo.cs" />
  </ItemGroup>
  <Target Name="ValidateLocalGameReferences" BeforeTargets="ResolveAssemblyReferences">
    <Error
      Condition="'$(PluginVideoRecordMonoBepInExCoreDir)' == ''"
      Text="未配置 Mono BepInEx core 目录。请创建 Local.Build.props 或设置环境变量 PLUGIN_VIDEO_RECORD_MONO_BEPINEX_CORE_DIR。" />
    <Error
      Condition="'$(PluginVideoRecordMonoManagedDir)' == ''"
      Text="未配置 Mono Managed 目录。请创建 Local.Build.props 或设置环境变量 PLUGIN_VIDEO_RECORD_MONO_MANAGED_DIR。" />
    <Error
      Condition="!Exists('$(PluginVideoRecordMonoBepInExCoreDir)\BepInEx.dll')"
      Text="Mono BepInEx 引用不存在: $(PluginVideoRecordMonoBepInExCoreDir)\BepInEx.dll" />
    <Error
      Condition="!Exists('$(PluginVideoRecordMonoManagedDir)\UnityEngine.CoreModule.dll')"
      Text="Mono Unity 引用不存在: $(PluginVideoRecordMonoManagedDir)\UnityEngine.CoreModule.dll" />
    <Error
      Condition="!Exists('$(PluginVideoRecordMonoManagedDir)\UnityEngine.dll')"
      Text="Mono Unity 引用不存在: $(PluginVideoRecordMonoManagedDir)\UnityEngine.dll" />
  </Target>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
</Project>
